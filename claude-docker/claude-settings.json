{
  "theme": "light",
  "statusLine": {
    "type": "command",
    "command": "claude-statusline"
  },
  "permissions": {
    "allow": [
      "Bash(jj diff*)",
      "Bash(jj log*)",
      "Bash(jj status*)",
      "Bash(jj show*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-jj-checkpoint"
          }
        ]
      }
    ]
  }
}
